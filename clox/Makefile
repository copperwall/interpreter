# Compiler to use.
CC = cc

# Compiler flags:
#   -Wall -Wextra : turn on most warnings
#   -std=c11      : use the C11 standard
#   -g            : emit debug symbols (needed for lldb/the Zed debugger)
#   -MMD          : as a side effect of compiling, write a .d file listing the
#                   headers each .c depends on (skips system headers)
#   -MP           : add a dummy target for each header so deleting/renaming a
#                   header doesn't break the build with a "no rule" error
CFLAGS = -Wall -Wextra -std=c11 -g -MMD -MP

# All .c files in this directory.
SRCS = $(wildcard *.c)
# Corresponding object files (foo.c -> foo.o).
OBJS = $(SRCS:.c=.o)
# Corresponding dependency files (foo.o -> foo.d), generated by -MMD.
DEPS = $(OBJS:.o=.d)
# Name of the final binary.
TARGET = clox

# Link all object files into the final binary.
$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $(OBJS)

# Compile each .c into a .o. This also produces the matching .d file.
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# Remove build artifacts.
clean:
	rm -f $(OBJS) $(DEPS) $(TARGET)

# Pull in the auto-generated header dependencies. Each .d file contains rules
# like "main.o: main.c chunk.h common.h", so editing a header now correctly
# forces the dependent .o files to rebuild. The leading '-' means "don't error
# if the .d files don't exist yet" (e.g. on the very first build).
-include $(DEPS)

.PHONY: clean
